/* Skeleton Loader */
.skeleton {
    background: linear-gradient(90deg, var(--card-bg) 25%, var(--card-border) 50%, var(--card-bg) 75%);
    background-size: 200% 100%;
    animation: skeleton-loading 1.5s infinite;
    border-radius: 8px;
}

@keyframes skeleton-loading {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}
:root {
    --bg-main: #0a0a0a;
    --card-bg: #161616;
    --card-border: #262626;
    --text-main: #f4f4f5;
    --text-muted: #a1a1aa;
    --brand-primary: #3b82f6;
    --header-bg: rgba(10, 10, 10, 0.8);
}

:root.light {
    --bg-main: #f8fafc;
    --card-bg: #ffffff;
    --card-border: #e2e8f0;
    --text-main: #0f172a;
    --text-muted: #64748b;
    --brand-primary: #2563eb;
    --header-bg: rgba(248, 250, 252, 0.8);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--bg-main);
    color: var(--text-main);
    font-family: 'Inter', sans-serif;
    line-height: 1.5;
    transition: background-color 0.3s, color 0.3s;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
}

/* Typography */
h1, h2, h3, .font-display {
    font-family: 'Outfit', sans-serif;
}

a {
    text-decoration: none;
    color: inherit;
}

/* Header */
header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    border-bottom: 1px solid var(--card-border);
    background-color: var(--header-bg);
    backdrop-filter: blur(12px);
    height: 64px;
}

.header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
}

.logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
}

.logo-icon {
    width: 32px;
    height: 32px;
    background-color: var(--brand-primary);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    overflow: hidden; /* Ensure image respects border-radius */
}

.logo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.logo-text-animated {
    position: relative;
    display: inline-flex;
    align-items: center;
}

.logo-word {
    white-space: nowrap;
}

.logo-ball {
    position: absolute;
    top: -16px;
    left: 0;
    font-size: 14px;
    line-height: 1;
    opacity: 0;
    pointer-events: none;
    z-index: 5;
    will-change: transform;
}

nav {
    display: none;
    gap: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
}

nav a:hover, nav a.active {
    color: var(--text-main);
}

.header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.5rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s, color 0.2s;
}

.icon-btn:hover {
    background-color: var(--card-bg);
    color: var(--text-main);
}

.menu-toggle {
    display: block;
}

/* Mobile Menu */
#mobileMenu {
    display: none;
    flex-direction: column;
    padding: 1rem;
    gap: 1rem;
    border-bottom: 1px solid var(--card-border);
    background-color: var(--bg-main);
}

#mobileMenu.open {
    display: flex;
}

/* Hero Section */
.hero {
    text-align: center;
    padding: 5rem 0;
}

.hero h1 {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    background: linear-gradient(to bottom, var(--text-main), var(--text-muted));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

@media (min-width: 768px) {
    .hero h1 { font-size: 4.5rem; }
    nav { display: flex; }
    .menu-toggle { display: none; }
}

.hero p {
    color: var(--text-muted);
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto 2.5rem;
}

.search-container {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
}

.search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
}

.search-input {
    width: 100%;
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 1rem;
    padding: 1rem 1rem 1rem 3rem;
    color: var(--text-main);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
}

.search-input:focus {
    border-color: var(--brand-primary);
}

/* Tool Sections */
.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
}

.section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.more-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--brand-primary);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    transition: opacity 0.2s;
}

.more-link:hover {
    opacity: 0.8;
    text-decoration: underline;
}

.section-indicator {
    width: 6px;
    height: 32px;
    border-radius: 99px;
}

.mb-24 {
    margin-bottom: 3rem;
}

/* Rainbow Separator */
.rainbow-separator {
    height: 1px;
    width: 100%;
    margin: 1.5rem 0;
    background: linear-gradient(90deg, 
        transparent 0%, 
        rgba(255, 0, 0, 0.8) 15%, 
        rgba(255, 165, 0, 0.8) 25%, 
        rgba(255, 255, 0, 0.8) 35%, 
        rgba(0, 128, 0, 0.8) 50%, 
        rgba(0, 0, 255, 0.8) 65%, 
        rgba(75, 0, 130, 0.8) 75%, 
        rgba(238, 130, 238, 0.8) 85%, 
        transparent 100%
    );
    border: none;
    opacity: 0.5;
}

/* Grid Layouts */
.grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

@media (min-width: 1024px) {
    .grid { grid-template-columns: repeat(4, 1fr); }
}

/* Trending Section - List View */
.section-trending .grid {
    grid-template-columns: 1fr;
}

.section-trending .glass-card {
    flex-direction: row;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 1.5rem;
}

.section-trending .card-header {
    margin-bottom: 0;
}

.section-trending .card-desc {
    display: block;
}

/* Compact Grid Cards (Other Sections) */
.section-grid .glass-card {
    text-align: center;
    padding: 1.5rem 1rem;
    justify-content: center;
}

.section-grid .card-header {
    justify-content: center;
    margin-bottom: 0.5rem;
}

.section-grid .card-desc,
.section-grid .card-footer {
    display: none;
}

.section-grid .card-title {
    font-size: 1rem;
    margin-bottom: 0;
}

.glass-card {
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 1.25rem;
    padding: 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
}

.glass-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -12px rgba(var(--accent-rgb, 59, 130, 246), 0.35);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
}

.card-icon {
    padding: 0.75rem;
    border-radius: 12px;
    background-color: var(--bg-main);
    display: flex;
    align-items: center;
    justify-content: center;
}

.trending-badge {
    font-size: 10px;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: 99px;
    background-color: rgba(249, 115, 22, 0.1);
    color: #f97316;
    border: 1px solid rgba(249, 115, 22, 0.2);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 3px;
}

.fire-icon {
    font-size: 0.75em;
    line-height: 1;
}

.card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
}

.card-desc {
    color: var(--text-muted);
    font-size: 0.875rem;
    flex-grow: 1;
}

.card-footer {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
}

.glass-card:hover .card-footer {
    color: var(--text-main);
}

/* Blog Cards */
.blog-card {
    padding: 0;
    overflow: hidden;
}

.blog-card-horizontal {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: row;
    align-items: center;
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 1.5rem;
    transition: transform 0.3s, border-color 0.3s;
}

@media (max-width: 640px) {
    .blog-card-horizontal {
        flex-direction: column;
        align-items: flex-start;
    }
    .blog-img-horizontal {
        width: 100%;
        height: 160px;
        margin: 0;
        border-radius: 1.5rem 1.5rem 0 0;
    }
}

.blog-card-horizontal:hover {
    transform: translateY(-5px);
    border-color: var(--brand-primary);
}

.blog-img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    opacity: 0.8;
    transition: opacity 0.3s;
}

.blog-img-horizontal {
    width: 120px;
    height: 120px;
    object-fit: cover;
    opacity: 0.8;
    transition: opacity 0.3s;
    border-radius: 1rem;
    margin: 1rem;
}

.blog-card:hover .blog-img,
.blog-card-horizontal:hover .blog-img-horizontal {
    opacity: 1;
}

.blog-content {
    padding: 1.5rem;
}

.blog-meta {
    font-size: 10px;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
}

/* FAQ Accordion */
.faq-section {
    margin-top: 6rem;
    margin-bottom: 6rem;
}

.faq-title {
    font-size: 2.25rem;
    margin-bottom: 3rem;
    text-align: center;
    color: var(--text-main);
}

.faq-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-left: 3px solid var(--card-border);
    border-radius: 0.875rem;
    overflow: hidden;
    transition: all 0.2s ease;
}

.faq-item:hover {
    border-left-color: var(--brand-primary);
}

.faq-question {
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-weight: 600;
    color: var(--text-main);
    user-select: none;
    font-size: 1rem;
}

.faq-question i {
    transition: transform 0.3s ease;
    color: var(--text-muted);
    width: 20px;
    height: 20px;
}

.faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding: 0 1.5rem;
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.9375rem;
}

.faq-item.active {
    border-color: var(--brand-primary);
    background-color: rgba(var(--brand-primary-rgb, 59, 130, 246), 0.02);
}

.faq-item.active .faq-answer {
    max-height: 300px;
    padding-bottom: 1.25rem;
}

.faq-item.active .faq-question i {
    transform: rotate(180deg);
    color: var(--brand-primary);
}

/* SEO Section Enhancements */
.seo-content {
    margin-top: 6rem;
    padding: 5rem 2rem;
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 2.5rem;
    position: relative;
    overflow: hidden;
}

.seo-header {
    text-align: center;
    margin-bottom: 4rem;
}

.seo-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text-main);
}

.seo-header p {
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.1rem;
}

.seo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
}

.seo-card {
    background: var(--bg-main);
    padding: 2rem;
    border-radius: 1.5rem;
    border: 1px solid var(--card-border);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.seo-card:hover {
    transform: translateY(-4px);
    border-color: var(--brand-primary);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
}

.seo-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
}

.seo-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0;
}

.seo-card p {
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.9rem;
    margin: 0;
}

.seo-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--card-border);
    text-align: center;
}

.seo-footer p {
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
}

.seo-tag {
    display: inline-block;
    margin: 0 6px;
    font-weight: 600;
}

/* Footer */
footer {
    margin-top: 5rem;
    padding: 4rem 0 2rem;
    border-top: 1px solid var(--card-border);
    background-color: var(--card-bg);
    color: var(--text-main);
}

.footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .footer-grid {
        grid-template-columns: 2fr 1fr 1fr 1fr;
    }
}

.footer-col h4 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-main);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.footer-col p {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 1rem;
}

.footer-col ul {
    list-style: none;
}

.footer-col ul li {
    margin-bottom: 0.75rem;
}

.footer-col ul li a {
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color 0.2s;
}

.footer-col ul li a:hover {
    color: var(--brand-primary);
}

.footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--card-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
}

@media (min-width: 768px) {
    .footer-bottom {
        flex-direction: row;
        justify-content: space-between;
        text-align: left;
    }
}

.footer-copy {
    color: var(--text-muted);
    font-size: 0.875rem;
}

/* Compact Related Tools */
.related-tools-container {
    margin-top: 4rem;
    margin-bottom: 2rem;
}

.related-tools-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    width: 100%;
}

@media (min-width: 768px) {
    .related-tools-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }
}

@media (min-width: 1024px) {
    .related-tools-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }
}

.compact-tool-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 1rem;
    transition: all 0.2s;
    min-width: 0; /* Important for grid/flex shrinking */
}

.compact-tool-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background-color: rgba(var(--accent-rgb, 59, 130, 246), 0.05);
}

.compact-tool-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-main);
    border-radius: 8px;
    color: var(--accent);
}

.compact-tool-name {
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0; /* Essential for ellipsis in flexbox */
}

/* Category Specific Colors with RGB for transparency */
.color-trending { --accent: #f97316; --accent-rgb: 249, 115, 22; }
.color-pdf { --accent: #ef4444; --accent-rgb: 239, 68, 68; }
.color-image { --accent: #3b82f6; --accent-rgb: 59, 130, 246; }
.color-security { --accent: #06b6d4; --accent-rgb: 6, 182, 212; }
.color-dev { --accent: #eab308; --accent-rgb: 234, 179, 8; }
.color-utility { --accent: #8b5cf6; --accent-rgb: 139, 92, 246; }
.color-seo { --accent: #10b981; --accent-rgb: 16, 185, 129; }
.color-audio { --accent: #00fa9a; --accent-rgb: 0, 250, 154; }
.color-youtube { --accent: #D902EE; --accent-rgb: 217, 2, 238; }

.glass-card:hover { border-color: var(--accent); }
.glass-card:hover .card-title { color: var(--accent); }
.card-icon { color: var(--accent); }
.section-indicator { background-color: var(--accent); }

/* SEO Extra Block — optional per-tool content from the admin generator */
.seo-extra-block {
    margin: 3rem 0;
    padding: 2rem;
    border-radius: 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-left: 4px solid var(--accent);
}

.seo-extra-block h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--accent);
}

.seo-extra-block p {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 1rem;
    margin-bottom: 1.5rem;
}

.comparison-table {
    width: 100%;
    border-collapse: collapse;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--card-border);
}

.comparison-table th,
.comparison-table td {
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--card-border);
}

.comparison-table th {
    background: rgba(var(--accent-rgb), 0.12);
    color: var(--accent);
    font-weight: 700;
}

.comparison-table tr:last-child td {
    border-bottom: none;
}
